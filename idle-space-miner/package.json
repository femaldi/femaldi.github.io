{
  "name": "ore-legacy",
  "version": "0.1.0",
  "description": "ORE-Legacy",
  "main": "electron/main.js",
  "author": "Facundo Emaldi",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "npm run prepare-renderer && electron .",
    "prepare-renderer": "node scripts/prepare-renderer.js",
    "obfuscate-renderer": "node scripts/obfuscate-renderer.js",
    "build:renderer": "npm run prepare-renderer && npm run obfuscate-renderer",
    "dist:win": "npm run build:renderer && electron-builder --win dir",
    "dist:win-installer": "npm run build:renderer && electron-builder --win nsis",
    "steam:stage:win": "npm run dist:win && node scripts/stage-steam-win.js"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "fs-extra": "latest",
    "javascript-obfuscator": "latest"
  }
}